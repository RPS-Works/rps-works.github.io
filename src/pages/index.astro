---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card/index.astro";
---

<script>
  import { stagger, animate, type AnimationSequence } from "motion";
  import { loaderAnimation } from "../lib/constants";
  const cards = document.querySelectorAll(".card");

  const sequence = [
    loaderAnimation,
    [
      cards,
      { y: ["40%", "0%"], opacity: [0, 1] },
      {
        type: "spring",
        at: "-0.1",
        delay: stagger(0.3),
      },
    ],
  ];

  animate(sequence as AnimationSequence);
</script>

<Layout
  description="RPS Works — links and resources"
  title="RPS Works"
>
  <main
    class="text-white m-auto p-2 grid gap-2 max-w-6xl overflow-hidden relative w-full sm:p-4 sm:gap-2 md:grid-cols-2 md:gap-3 md:p-6 lg:h-screen lg:grid-rows-8 lg:grid-cols-4 lg:gap-4 lg:max-h-[800px]"
  >
    <!-- Official site preview -->
    <Card colSpan="md:col-span-3" rowSpan="md:row-span-4">
      <p class="text-sm text-gray-500">Official site preview</p>
    </Card>

    <!-- Featured Projects list -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-6">
      <p class="text-sm text-gray-500">Featured Projects list</p>
    </Card>

    <!-- YouTube -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-4">
      <p class="text-sm text-gray-500">YouTube</p>
    </Card>

    <!-- Bilibili -->
    <Card colSpan="md:col-span-2" rowSpan="md:row-span-2">
      <p class="text-sm text-gray-500">Bilibili</p>
    </Card>

    <!-- portals -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-2">
      <p class="text-sm text-gray-500">portals</p>
    </Card>

    <!-- Members' avatars -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <p class="text-sm text-gray-500">Members' avatars</p>
    </Card>

    <!-- RPS Guides -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-2">
      <p class="text-sm text-gray-500">RPS Guides</p>
    </Card>

    <!-- GitHub, Email, ... -->
    <Card colSpan="md:col-span-1" rowSpan="md:row-span-1">
      <p class="text-sm text-gray-500">GitHub, Email, ...</p>
    </Card>
  </main>
</Layout>
